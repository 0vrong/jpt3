<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.resourcemonitor.controller.SettingsController"
      prefWidth="740.0" prefHeight="700.0">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <children>
        <Label text="Настройки мониторинга"/>

        <Label text="Интервал проверки (секунды)"/>
        <TextField fx:id="intervalField" promptText="Например: 60"/>

        <Label text="Память - порог в процентах"/>
        <TextField fx:id="memoryPercentField" promptText="Например: 85"/>

        <Label text="Память - порог в абсолютном значении (ГБ)"/>
        <TextField fx:id="memoryAbsoluteField" promptText="Например: 2"/>

        <Label text="Настройки по каждому диску"/>

        <ScrollPane fitToWidth="true" prefHeight="420.0" vbarPolicy="ALWAYS">
            <content>
                <VBox fx:id="disksContainer" spacing="14.0" prefWidth="680.0"/>
            </content>
        </ScrollPane>

        <Button text="Запустить программу" onAction="#handleSaveAndStart"/>
        <Button text="Проверить сейчас" onAction="#handleCheckNow"/>
        <Button text="Выйти из профиля" onAction="#handleLogout"/>

        <Label fx:id="messageLabel" text=""/>
    </children>
</VBox>