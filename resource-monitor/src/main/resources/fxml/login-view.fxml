<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.resourcemonitor.controller.LoginController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>
        <Label text="Вход в систему"/>
        <TextField fx:id="loginField" promptText="Введите логин"/>
        <PasswordField fx:id="passwordField" promptText="Введите пароль"/>
        <Button text="Войти" onAction="#handleLogin"/>
        <Label fx:id="messageLabel" text=""/>
    </children>
</VBox>